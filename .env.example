# ==============================================================================
# finance-sync — Environment Variables Reference
# ==============================================================================
# Copy this file to .env and fill in all values before running the application.
#
#   cp .env.example .env
#
# ── Runtime Environment ────────────────────────────────────────────────────────────

# Deployment environment: dev, staging, prod
# Controls debug mode, JSON logging, etc.
# Default: dev
# APP_ENVIRONMENT=prod

# ── Application ────────────────────────────────────────────────────────────────────

# Application name (used in OpenAPI title)
# APP_NAME=finance-sync

# Application version
# APP_VERSION=0.1.0

# Enable debug mode (overridden by APP_ENVIRONMENT in dev/staging)
# DEBUG=false

# ── Logging ────────────────────────────────────────────────────────────────────────

# Minimum log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ── CORS ───────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (default: *)
# CORS_ORIGINS=*

# ── PostgreSQL ─────────────────────────────────────────────────────────────────────

# Database connection string (alternative to individual POSTGRES_* vars)
# If set, takes precedence over POSTGRES_* variables below.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# DATABASE_URL=postgresql+asyncpg://finance_sync:change-me@localhost:5432/finance_sync

# Individual database settings (used when DATABASE_URL is not set)
POSTGRES_DB=finance_sync
POSTGRES_USER=finance_sync
# REQUIRED: Database password
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Connection pool sizing
# DATABASE_POOL_MIN_SIZE=2
# DATABASE_POOL_MAX_SIZE=10

# Migration user (DDL-only for Alembic — run scripts/setup-migration-user.sql once)
# ASYNC_DB_URL=postgresql+asyncpg://finance_sync_migration:change-me-to-a-strong-password@localhost:5432/finance_sync

# ── Redis ──────────────────────────────────────────────────────────────────────────

# Redis connection string (alternative to individual REDIS_* vars)
# Format: redis://[[username]:[password]]@host:port/db
# REDIS_URL=redis://:password@localhost:6379/0

# Redis password (used when REDIS_URL is not set — assumes localhost:6379/0)
# REDIS_PASSWORD=

# ── Security / JWT ─────────────────────────────────────────────────────────────────

# REQUIRED: Secret key for JWT signing. Must be at least 16 characters.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-secret-key-at-least-16-chars

# Access token lifetime (minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime (days)
# REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT signing algorithm (default: HS256)
# JWT_ALGORITHM=HS256

# ── Credential Encryption ──────────────────────────────────────────────────────────

# REQUIRED if you plan to store provider credentials (e.g. Plaid, Yodlee, bunq).
# Hex-encoded 32-byte AES-256-GCM master key.
# Generate with: openssl rand -hex 32
# MASTER_ENCRYPTION_KEY=

# ── Connectors: bunq ────────────────────────────────────────────────────────
#
# bunq API key — required for the bunq connector.
# Obtain from the bunq app: Profile → Security → API keys
# BUNQ_API_KEY=
#
# bunq API base URL (optional — defaults to https://api.bunq.com/v1)
# Override with "https://sandbox.bunq.com/v1" for sandbox testing.
# BUNQ_API_BASE_URL=https://api.bunq.com/v1
